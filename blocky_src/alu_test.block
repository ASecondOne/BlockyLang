<define>
    let num = 10;
    let other = 3;
    let zero = 0;
    let foo2 = 7;
    let text = "hello";
</define>

<execute>
    println "VALID BASELINE CASES";
    println "10 + 3 (expected 13):";
    println num + other;
    println "10 - 3 (expected 7):";
    println num - other;
    println "10 * 3 (expected 30):";
    println num * other;
    println "10 / 2 (expected 5):";
    println num / 2;
    println "precedence: 2 + 3 * 4 (expected 14):";
    println 2 + 3 * 4;

    println "NON-FATAL MALFORMED CASES";
    println "trailing operator: 10 + (should be an error):";
    println num +;
    println "missing variable on right: 10 + missing (should be an error):";
    println num + missing;
    println "two operators: 10 + * 3 (should be an error):";
    println num + * other;
    println "two operands without operator: 2 3 (should be an error):";
    println 2 3;
    println "unknown text after a number: 2 garbage (should be an error):";
    println 2 garbage;
    println "unknown character: 2 $ + 3 (should be an error):";
    println 2 $ + 3;
    println "ignored parentheses: (2 + 3) * 4 (expected 20 if supported):";
    println (2 + 3) * 4;
    println "scientific notation: 1e3 (expected 1000 if supported):";
    println 1e3;
    println "unary minus after multiplication: 2 * -3 (expected -6):";
    println 2 * -3;
    println "repeated plus: 4 + + 3 (should be an error):";
    println 4 + + 3;
    println "division by zero (should report an error without panicking):";
    println 1 / zero;
    println "string used in arithmetic (should report a type error):";
    println text + 1;
    println "variable containing a digit on the left (expected 8):";
    println foo2 + 1;

    println "FATAL CASES START HERE";
    println "The first panic/exit prevents the remaining fatal cases from running.";
    println "Move the case you want to inspect directly below this label.";

    println "variable containing a digit on the right: 1 + foo2 (currently may panic):";
    println 1 + foo2;
    println "leading operator: + 2 (currently may panic):";
    println + 2;
    println "undefined left operand: missing + 2 (currently may panic):";
    println missing + 2;
    println "leading unary minus: -3 (currently may panic):";
    println -3;
</execute>
